package com.example.demo.service;

import com.example.demo.dto.EmployeeDTO;
import com.example.demo.entity.Employee;
import com.example.demo.repository.EmployeeRepository;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;

import java.util.Optional;

import static org.junit.jupiter.api.Assertions.*;

class EmployeeServiceTest {

    @Test
    void testGetById() {
        EmployeeRepository repo = Mockito.mock(EmployeeRepository.class);
        EmployeeService service = new EmployeeService(repo);

        Employee emp = new Employee(1L, "Test", "test@mail.com");

        Mockito.when(repo.findById(1L)).thenReturn(Optional.of(emp));

        Employee result = service.getById(1L);

        assertEquals("Test", result.getName());
    }
}
